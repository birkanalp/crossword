# ──────────────────────────────────────────────────────────────────────────────
# Bulmaca – Local Environment Variables
# Copy this file to .env and fill in the values.
# The defaults below work for local development out of the box.
# ──────────────────────────────────────────────────────────────────────────────

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres

# ── JWT (change in production!) ───────────────────────────────────────────────
# Well-known Supabase local-dev defaults – safe for local only
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# These JWTs are signed with JWT_SECRET above. Regenerate if you change JWT_SECRET:
# node -e "const c=require('crypto');const s='super-secret-jwt-token-with-at-least-32-characters-long';const b=s=>Buffer.from(s).toString('base64url');const h=b(JSON.stringify({alg:'HS256',typ:'JWT'}));const i=Math.floor(Date.now()/1000);const e=i+10*365*24*3600;const p=(r)=>b(JSON.stringify({role:r,iss:'supabase-demo',iat:i,exp:e}));const sg=(d)=>c.createHmac('sha256',s).update(d).digest('base64url');const anon=h+'.'+p('anon')+'.'+sg(h+'.'+p('anon'));const svc=h+'.'+p('service_role')+'.'+sg(h+'.'+p('service_role'));console.log('ANON_KEY='+anon);console.log('SERVICE_ROLE_KEY='+svc);"
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3NzIxMTY0MTgsImV4cCI6MjA4NzQ3NjQxOH0.T7GMZllJJFOCL47MTIfpTpDY0A22xTcBfeJ9q7Gfibw
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTc3MjExNjQxOCwiZXhwIjoyMDg3NDc2NDE4fQ.YOo7Yt9gY1UDJ_7eNbyjzX2BEkmRctKrHFS0hfIDDHM

# ── API / Auth ─────────────────────────────────────────────────────────────────
API_EXTERNAL_URL=http://localhost:54321
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# ── SMTP (uses local Inbucket by default) ─────────────────────────────────────
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_USER=fake@example.com
SMTP_PASS=fake-smtp-password
SMTP_SENDER_NAME=Bulmaca
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=true

# ── Studio ────────────────────────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=Bulmaca
STUDIO_DEFAULT_PROJECT=Bulmaca Local

# ── Ports (must match backend/supabase/config.toml) ──────────────────────────
KONG_HTTP_PORT=54321
POSTGRES_PORT=54322
STUDIO_PORT=54323
INBUCKET_PORT=54324
SMTP_MAIL_PORT=54325
POP3_PORT=54326

# ── Expo / Frontend ────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7W9fDQALeQAAAuklFMRCUjhJZJHnA3KNIhw

# ── Cron AI trigger (auto-review after puzzle generation) ───────────────────────
CRON_SECRET=cron-trigger-ai-secret

# ── OpenAI (AI Review + Hint Generation) ──────────────────────────────────────
#
# Required for the AI review pipeline (cronTriggerAiReview, admin AI review,
# and admin hint generation).
#
# LOCAL: set here in .env
# PRODUCTION: set as Supabase Edge Function secrets:
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set OPENAI_REVIEW_MODEL=gpt-4o-mini
#
# Models:
#   gpt-4o-mini  — recommended (cheap, fast, supports structured JSON output)
#   gpt-4o       — stronger fallback (uncomment below to use)
#
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_REVIEW_MODEL=gpt-4o-mini
# OPENAI_REVIEW_MODEL=gpt-4o
