# ──────────────────────────────────────────────────────────────────────────────
# Bulmaca Frontend – Environment Variables Template
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local dev: http://localhost:54321
# Production: https://YOUR_PROJECT.supabase.co
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOi...

# Preview/production fail-fast policy:
# - APP_ENV=preview|production iken SUPABASE_URL ve SUPABASE_ANON_KEY zorunlu.
# - development modunda local fallback kullanilir.
APP_ENV=development

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Get from: app.revenuecat.com → Project → API Keys
REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AdMob ─────────────────────────────────────────────────────────────────────
# Get from: admob.google.com → Apps → Ad units
# Leave empty in dev — test IDs are used automatically when __DEV__ is true
ADMOB_BANNER_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_BANNER_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ── Analytics ─────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://us.i.posthog.com

# ── Auth Providers ────────────────────────────────────────────────────────────
AUTH_APPLE_ENABLED=false
AUTH_GOOGLE_ENABLED=false
