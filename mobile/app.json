{
  "expo": {
    "name": "Bulmaca",
    "slug": "bulmaca",
    "version": "1.0.0",
    "scheme": "bulmaca",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bulmaca.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.bulmaca.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1a2e",
          "image": "./assets/splash.png"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "bulmaca",
          "organization": "bulmaca-org"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6329550253975291~9574284134",
          "iosAppId": "ca-app-pub-6329550253975291~5275946470"
        }
      ]
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1828f3ad-8c17-4753-b35e-7174026dcb70"
      },
      "supabaseUrl": "http://localhost:54321",
      "sentryDsn": "",
      "revenueCatApiKeyIos": "",
      "revenueCatApiKeyAndroid": "",
      "admobBannerIos": "",
      "admobBannerAndroid": "",
      "admobInterstitialIos": "",
      "admobInterstitialAndroid": "",
      "admobRewardedIos": "",
      "admobRewardedAndroid": "",
      "posthogApiKey": "",
      "posthogHost": "https://us.i.posthog.com"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/1828f3ad-8c17-4753-b35e-7174026dcb70"
    },
    "runtimeVersion": "1.0.0"
  }
}
